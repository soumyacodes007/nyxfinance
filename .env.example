COMPOSE_PROJECT_NAME=confidential-prefunding

API_PORT=3001
BUSINESS_SERVER_PORT=8091
FRONTEND_PORT=3000
ANCHOR_SEP_PORT=8080
ANCHOR_PLATFORM_API_PORT=8085

APP_STATE_DB_PATH=./data/app.sqlite
APP_DATA_HOST_DIR=./data
FRONTEND_API_BASE_URL=http://api:3001
PREFUNDING_FEE_BPS=35
WATCHER_POLL_INTERVAL_MS=15000
PROVER_POLL_INTERVAL_MS=5000
OZ_CONFIDENTIAL_ROOT=./oz-confidential
ORACLE_MODE=mock
ORACLE_SOURCE=demo_adapter
REFLECTOR_PULSE_CONTRACT_ID=CCYOZJCOPG34LLQQ7N24YXBM7LL62R7ONMZ3G6WZAAYPB5OYKOMJRN63
REFLECTOR_BASE_ASSET=USDC
REFLECTOR_QUOTE_ASSET=USDC
REFLECTOR_STALENESS_SECONDS=900
PROVER_MODE=alpha_demo_prover_worker
DEMO_ANCHOR_PROFILE=alpha
DEMO_SEP31_TRANSACTION_ID=sep31-alpha-001

# Frontend / Vercel public build variables.
# Set NEXT_PUBLIC_API_URL in Vercel to the public HTTPS URL of the API service.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEMO_SEP31_TRANSACTION_ID=sep31-alpha-001

STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

ANCHOR_PLATFORM_URL=http://localhost:8080
ANCHOR_PLATFORM_CONTAINER_URL=http://anchor-platform:8080
ANCHOR_PLATFORM_PUBLIC_URL=http://localhost:8080
ANCHOR_STELLAR_TOML_URL=http://localhost:8080/.well-known/stellar.toml

ANCHOR_DB_USER=postgres
ANCHOR_DB_PASSWORD=password
ANCHOR_DB_NAME=postgres

SECRET_SEP6_MORE_INFO_URL_JWT_SECRET=secret_sep6_more_info_url_jwt_secret
