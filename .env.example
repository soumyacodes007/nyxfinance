SECRET_SEP45_JWT_SECRET=secret_sep45_secret_secret_sep45_secret
SECRET_SEP24_INTERACTIVE_URL_JWT_SECRET=secret_sep24_interactive_url_jwt_secret
SECRET_SEP24_MORE_INFO_URL_JWT_SECRET=secret_sep24_more_info_url_jwt_secret

HOST_SEP10_ACCOUNT=REPLACE_ME
HOST_SEP10_SECRET_KEY=REPLACE_ME
