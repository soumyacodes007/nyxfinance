CREDIT_EXECUTOR_SECRET_KEY=REPLACE_ME
REQUIRE_CONFIDENTIAL_REPAYMENT_TRANSFER=false

# Exported by the Alpha/CreditExecutor-controlled confidential token prover.
# These are opaque OZ ConfidentialToken XDR payloads, not plaintext amounts.
DRAW_TRANSFER_DATA_XDR_BASE64=REPLACE_ME
DRAW_AUDITOR_PAYLOAD_JSON=
REPAYMENT_TRANSFER_DATA_XDR_BASE64=REPLACE_ME
REPAYMENT_AUDITOR_PAYLOAD_JSON=

