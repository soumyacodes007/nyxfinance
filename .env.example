# Optional second anchor profile. Populate with:
# NYX_DEMO_ANCHOR_PROFILE=beta cargo run -q -p oz-confidential-runner -- prove-of-life
# npm run refresh:confidential-artifacts -- .env oz-confidential/state/proof-of-life-report.json beta
BETA_PUBLIC_KEY=REPLACE_ME
BETA_ANCHOR_SECRET_KEY=REPLACE_ME
BETA_ORGANIZATION_NAME=Beta Remit
BETA_EMAIL_ADDRESS=ops@beta-remit.example

PARTICIPANT_POLICY_CONTRACT_ID=TODO_PHASE2
COLLATERAL_POLICY_CONTRACT_ID=TODO_PHASE2
ORACLE_ADAPTER_CONTRACT_ID=TODO_PHASE4
COLLATERAL_LOCK_CONTRACT_ID=TODO_PHASE2
PREFUNDING_CREDIT_LINE_CONTRACT_ID=TODO_PHASE2
COLLATERAL_SUFFICIENCY_VERIFIER_CONTRACT_ID=TODO_PHASE4
COLLATERAL_TOKEN_CONTRACT_ID=TODO_PHASE4
CONFIDENTIAL_CUSDC_CONTRACT_ID=TODO_PHASE2_CUSDC
